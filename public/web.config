<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <system.web>
      <compilation debug="false" targetFramework="4.5" />
      <httpRuntime targetFramework="4.5" requestPathInvalidCharacters="&lt;,&gt;,:,*,?,&amp;,&quot;,&amp;,&amp;"/>
    </system.web>
    <directoryBrowse enabled="true" />
  </system.webServer>
</configuration>

